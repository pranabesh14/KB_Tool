# =============================================================================
# KB Tool - Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================


# --- Azure OpenAI (required) --------------------------------------------------

AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-01
AZURE_DEPLOYMENT_CHAT=gpt-4o
AZURE_DEPLOYMENT_EMBED=text-embedding-ada-002


# --- Azure AD (shared by Confluence + SharePoint) -----------------------------
# App Registration created in Azure Portal -> App registrations

# Your Azure AD tenant ID (found in Azure Portal -> Azure Active Directory -> Overview)
AZURE_AD_TENANT_ID=your-tenant-id-here

# App Registration Client ID (found in App Registration -> Overview)
AZURE_AD_CLIENT_ID=your-client-id-here

# App Registration Client Secret
# REQUIRED for shared server deployments - enables non-interactive auth
# Create in: App Registration -> Certificates & secrets -> New client secret
# Leave blank only for single-user dev machines (triggers browser login)
AZURE_AD_CLIENT_SECRET=your-client-secret-here


# --- Confluence ---------------------------------------------------------------

# Base URL of your Confluence Data Center instance
CONFLUENCE_BASE_URL=https://confluence.yourcompany.com

# API scope for Confluence access
# Format: api://<confluence-app-client-id>/.default
# Get the app client ID from whoever registered Confluence in Azure AD
AZURE_AD_CONFLUENCE_SCOPE=api://your-confluence-app-id/.default

# How many levels of internal links to follow (default: 2)
# 0 = starting page only, 1 = page + linked pages, 2 = + their links
CONFLUENCE_CRAWL_DEPTH=2


# --- SharePoint ---------------------------------------------------------------

# Base URL of your SharePoint On-Premise instance
SHAREPOINT_BASE_URL=https://sharepoint.yourcompany.com

# API scope for SharePoint access
# Format: api://<sharepoint-app-client-id>/.default
AZURE_AD_SHAREPOINT_SCOPE=api://your-sharepoint-app-id/.default


# --- Whisper (local speech-to-text) ------------------------------------------
# Controls the model size used for video/audio transcription
# Options  : tiny | base | small | medium | large
# Tradeoffs:
#   tiny   ->  39 MB  | fastest  | least accurate
#   base   ->  74 MB  | fast     | decent  (default)
#   small  -> 244 MB  | moderate | good
#   medium -> 769 MB  | slow     | very good
#   large  -> 1.5 GB  | slowest  | best
WHISPER_MODEL_SIZE=base


# --- HuggingFace (optional) ---------------------------------------------------
# Only needed for gated/private HuggingFace models.
# The CrossEncoder reranker and fallback embedding model are public
# and do NOT need this key.
# HUGGINGFACE_API_KEY=hf_...