# =============================================================================
# KB Tool — Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================================


# ─── Azure OpenAI (required) ──────────────────────────────────────────────────

# Your Azure OpenAI resource API key
AZURE_OPENAI_API_KEY=your_azure_openai_key_here

# Full endpoint URL of your Azure OpenAI resource
# Format: https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/

# API version — use the latest stable release
# See: https://learn.microsoft.com/en-us/azure/ai-services/openai/reference
AZURE_OPENAI_API_VERSION=2024-02-01


# ─── Azure OpenAI Deployment Names (required) ─────────────────────────────────
# These must match the deployment names you created in Azure AI Studio.

# Chat / completion model deployment (e.g. gpt-4o, gpt-4-turbo, gpt-35-turbo)
AZURE_DEPLOYMENT_CHAT=gpt-4o

# Embedding model deployment (e.g. text-embedding-ada-002, text-embedding-3-small)
# If left blank or missing, the app falls back to the local HuggingFace model:
#   BAAI/bge-base-en-v1.5  (no Azure creds needed, runs on CPU)
AZURE_DEPLOYMENT_EMBED=text-embedding-ada-002


# ─── HuggingFace (optional) ───────────────────────────────────────────────────
# Only required if you use gated/private HuggingFace models.
# The CrossEncoder reranker (cross-encoder/ms-marco-MiniLM-L-6-v2) and
# the fallback embedding model (BAAI/bge-base-en-v1.5) are both public
# and do NOT need this key.
# HUGGINGFACE_API_KEY=hf_...
